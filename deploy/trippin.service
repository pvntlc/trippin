[Unit]
Description=Trippin FastAPI Server
After=network.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/home/ubuntu/trippin/backend
Environment="PATH=/home/ubuntu/trippin/backend/venv/bin"
EnvironmentFile=/home/ubuntu/trippin/backend/.env
ExecStart=/home/ubuntu/trippin/backend/venv/bin/uvicorn main:app --host 0.0.0.0 --port 8002
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target

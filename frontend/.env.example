# 백엔드 API 주소
# 웹/iOS 시뮬레이터: http://localhost:8002
# 안드로이드 에뮬레이터: http://10.0.2.2:8002
# 실기기/운영: http://<서버IP 또는 도메인>
EXPO_PUBLIC_API_URL=http://localhost:8002

# 지도 표시용 Google Maps 키 (클라이언트 노출됨 — HTTP 리퍼러/앱 번들로 제한 권장)
# Maps JavaScript API(웹) + Maps SDK for Android/iOS 활성화 필요
EXPO_PUBLIC_GOOGLE_MAPS_KEY=your_google_maps_client_key_here

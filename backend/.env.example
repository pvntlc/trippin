# ── App ──────────────────────────────────────────────
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8002

# ── Auth (JWT) ───────────────────────────────────────
# 생성: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRE_MINUTES=43200   # 30일

# ── Google Maps Platform ─────────────────────────────
# 서버 전용 키 (Places API + Directions API 활성화 필요). 절대 프론트에 노출 금지.
GOOGLE_MAPS_API_KEY=your_google_maps_server_key_here

# ── Anthropic (리뷰 AI 요약) ─────────────────────────
# ANTHROPIC_API_KEY 는 시스템 예약 가능 → APP_ 접두사 사용
APP_ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── NAVITIME (일본 대중교통, RapidAPI) ───────────────
# 구글이 일본 transit 미지원 → NAVITIME Route(totalnavi) 사용
NAVITIME_API_KEY=your_navitime_rapidapi_key_here

# ── CORS ─────────────────────────────────────────────
# 콤마 구분. 개발 시 * 허용, 운영 시 실제 도메인만.
CORS_ORIGINS=*
